{
  "name": "vinyl-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "src/ui"
  ],
  "scripts": {
    "dev": "concurrently -k -n ui,worker -c green,blue \"npm:dev:ui\" \"npm:dev:worker\"",
    "dev:ui": "npm --workspace src/ui run dev",
    "dev:worker": "wrangler dev",
    "build": "npm --workspace src/ui run build",
    "deploy": "npm run build && wrangler deploy",
    "seed": "tsx scripts/seed.ts",
    "migrate": "wrangler d1 migrations apply DB --remote",
    "migrate:local": "wrangler d1 migrations apply DB --local",
    "reset": "bash scripts/reset.sh",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250604.0",
    "@types/node": "^25.9.2",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wrangler": "^4.99.0"
  },
  "dependencies": {
    "agents": "^0.15.0",
    "ai": "^6.0.199",
    "isomorphic-git": "^1.38.4",
    "workers-ai-provider": "^3.1.14",
    "zod": "^4.4.3"
  }
}
